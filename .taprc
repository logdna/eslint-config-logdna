esm: false
ts: false
jsx: false
browser: false
check-coverage: true
100: true
reporter: classic
nyc-arg:
- --all=true
- --exclude=example/**
- --exclude=test/**
- --exclude=*.config.js
- --exclude=template/**
output-file: coverage/.tap-output
coverage-report:
- text
- text-summary
- json
- json-summary
- html
files:
- test/*.js
